--[[
	Codegen Command

	Runs all code generation tasks: compiles networking, generates project links,
	and generates the sourcemap.
]]

local fs = require("@lute/fs")

local color = require("../utils/color")
local rojo = require("../lib/project/rojo")

local codegen = {}

-- Metadata for help command
codegen.name = "codegen"
codegen.description = "Runs all code generation (sourcemap only for now)"
codegen.usage = "lute run codegen"

-- Argument definitions for CLI parsing
codegen.arguments = {}

export type Options = {
	quiet: boolean?,
	dev: boolean?,
	generateSourcemap: boolean?,
}

local BUILD_CONFIG_PATH = "plugin/generated/buildConfig.luau"

local RELEASE_CONFIG = {
	pluginName = "Discover",
	widgetId = "DiscoverWidget",
	widgetTitle = "Discover",
	widgetName = "Discover",
	buttonId = "discover",
	buttonTitle = "Discover",
	buttonTooltip = "Browse and install Luau packages",
	peerId = "morgann1/studio-discover",
	toolbarTitle = "22:43",
	mediumName = "  22:43 Plugin Suite",
	icon = "rbxassetid://125842588490194",
}

local DEV_CONFIG = {
	pluginName = "Discover (Dev)",
	widgetId = "DiscoverDevWidget",
	widgetTitle = "Discover (Dev)",
	widgetName = "DiscoverDev",
	buttonId = "discover-dev",
	buttonTitle = "Discover (Dev)",
	buttonTooltip = "Browse and install Luau packages (dev build)",
	peerId = "morgann1/studio-discover-dev",
	toolbarTitle = "22:43 (Dev)",
	mediumName = "  22:43 Plugin Suite (Dev)",
	icon = "rbxassetid://132814924850541",
}

local function isDir(path: string): boolean
	return fs.exists(path) and fs.type(path) == "dir"
end

local function quote(value: string): string
	-- Escape backslashes and quotes, then wrap in double quotes.
	local escaped = value:gsub("\\", "\\\\"):gsub('"', '\\"')
	return `"{escaped}"`
end

local function serializeConfig(config: { [string]: string }, dev: boolean): string
	local keys = {
		"pluginName",
		"widgetId",
		"widgetTitle",
		"widgetName",
		"buttonId",
		"buttonTitle",
		"buttonTooltip",
		"peerId",
		"toolbarTitle",
		"mediumName",
		"icon",
	}

	local lines = {
		"--!strict",
		"-- This file is @generated by `lute run codegen` / `lute run build`. Do not edit.",
		"",
		"return table.freeze({",
		"\tisDev = " .. (if dev then "true" else "false") .. ",",
	}

	for _, key in keys do
		table.insert(lines, "\t" .. key .. " = " .. quote(config[key]) .. ",")
	end

	table.insert(lines, "})")
	table.insert(lines, "")

	return table.concat(lines, "\n")
end

local function writeBuildConfig(dev: boolean)
	if not isDir("plugin/generated") then
		fs.mkdir("plugin/generated")
	end

	local config = if dev then DEV_CONFIG else RELEASE_CONFIG
	local source = serializeConfig(config, dev)

	local handle = fs.open(BUILD_CONFIG_PATH, "w")
	fs.write(handle, source)
	fs.close(handle)
end

--[[
	Runs all code generation tasks.

	@param options Configuration options
	@return True if successful, false otherwise
]]
function codegen.run(options_: Options?): boolean
	local options: Options = options_ or {}
	local quiet = if options.quiet ~= nil then options.quiet else false
	local dev = if options.dev ~= nil then options.dev else false

	writeBuildConfig(dev)

	if options.generateSourcemap then
		-- Generate sourcemap
		local sourcemapSuccess, sourcemapError = rojo.sourcemap({
			projectFile = "plugin/default.project.json",
			output = "plugin/generated/sourcemap.json",
			absolute = true,
		})
		if not sourcemapSuccess then
			if not quiet then
				print(color.bold(color.red("Failed to generate sourcemap")))
				print(sourcemapError)
			end
			return false
		end

		if not quiet then
			print(color.bold(color.dim("Sourcemap generated successfully!")))
		end
	end

	if not quiet then
		print(color.bold(color.green("Code generation complete!")))
	end

	return true
end

return codegen
